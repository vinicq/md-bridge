# Reference Caddyfile. The bootstrap.sh script writes a tailored version
# of this file under /opt/md-bridge/Caddyfile and substitutes the actual
# domain. This copy lives in the repo for reference and code review.

# Replace example.com with the domain you pointed at the Oracle Cloud VM.
example.com {
    encode gzip

    # API routes go to the FastAPI container. Use handle, not handle_path:
    # the API serves every route under `/api` (e.g. `/api/health`), so the
    # prefix must be preserved. handle_path would strip `/api` and the
    # upstream would 404.
    handle /api/* {
        # Cap the request body at the edge so an oversized upload is rejected
        # before FastAPI spools it to disk. Track your MD_BRIDGE_MAX_UPLOAD_MB
        # plus ~2 MiB multipart overhead: 52 MiB here matches the 50 MB public
        # default the bootstrap ships (raise both together if you raise the cap).
        request_body {
            max_size 52MiB
        }
        reverse_proxy api:8000
    }

    # Everything else goes to the React static bundle behind nginx.
    handle {
        reverse_proxy web:80
    }
}
